                    <MinuteStepper label="Short Break (min)" value={shortBreakMinutes} max={30} onChange={onShortBreakMinutesChange} />
                    <MinuteStepper label="Long Break (min)" value={longBreakMinutes} max={60} onChange={onLongBreakMinutesChange} />
                </div>
